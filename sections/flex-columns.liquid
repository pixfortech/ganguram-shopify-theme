          ]
        },
        {
          "type": "_column",
          "blocks": [
            {
              "type": "heading",
              "settings": {
                "heading": "Pickup",
                "title_size": "h4"
              }
            },
            {
              "type": "rich-text",
              "settings": {
                "text": "<p>Let your customers know about local pickup</p>"
