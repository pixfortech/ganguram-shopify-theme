        "custom_liquid": "<div class=\"custom-description-section\">\n\n  {% if product.metafields.custom.intro_line %}\n    <h3>What it is</h3>\n    <p>{{ product.metafields.custom.intro_line }}</p>\n  {% endif %}\n\n  {% if product.metafields.custom.key_features %}\n    <h3>Key Features / Ingredients</h3>\n    <ul>\n      {% assign features = product.metafields.custom.key_features | newline_to_br | split: \"<br />\" %}\n      {% for line in features %}\n        <li>{{ line }}</li>\n      {% endfor %}\n    </ul>\n  {% endif %}\n\n  {% if product.metafields.custom.taste_summary %}\n    <h3>Taste & Texture</h3>\n    <p>{{ product.metafields.custom.taste_summary }}</p>\n  {% endif %}\n\n  {% if product.metafields.custom.serving_suggestions %}\n    <h3>Serving Suggestions</h3>\n    <p>{{ product.metafields.custom.serving_suggestions }}</p>\n  {% endif %}\n\n  {% if product.metafields.custom.shelf_life_storage %}\n    <h3>Shelf Life & Storage</h3>\n    <p>{{ product.metafields.custom.shelf_life_storage }}</p>\n  {% endif %}\n\n  {% if product.metafields.custom.allergen_note %}\n    <h3>Allergen Note</h3>\n    <p>{{ product.metafields.custom.allergen_note }}</p>\n  {% endif %}\n\n</div>",
