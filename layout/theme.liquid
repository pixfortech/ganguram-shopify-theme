<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{%- render 'lang-dir' -%}">
<head>

	<meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">

	{%- if settings.favicon -%}
		<link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 48, height: 48 }}" type="image/png" />
	{%- endif -%}

	{%- capture seo_title -%}
    {%- if template contains 'search' -%}
      {{ search.terms | replace: '*', '' | split: ' AND ' | last }} - {{ shop.name | escape }}
    {%- else -%}
      {{ page_title }}{% if current_tags %}{% assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name | escape }}{% endunless %}
    {%- endif -%}
  {%- endcapture -%}

	<title>{{ seo_title }}</title>

	{%- if page_description -%}
		<meta name="description" content="{{ page_description | escape }}">
	{%- endif -%}

  {%- liquid
    render 'open-graph'
    unless settings.disable_microdata 
      render 'microdata-schema'
    endunless
  -%}

  <link rel="canonical" href="{{ canonical_url }}">

  <link rel="preconnect" href="https://cdn.shopify.com">
  {%- unless settings.headings_font.system? and settings.body_font.system? -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {%- endunless -%}

  {%- render 'head-preloader' -%}
  {%- render 'head-variables' -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Pincode widget CSS in <head> (hotfix) so the location/caret icons never flash oversized before the late body CSS applies. {%- endcomment -%}
  {{ 'ganguram-delivery-widget.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Phase 1 UX polish (in <head> so the sticky header + buy-gate + out-of-stock rules apply before first paint): gate buy buttons until a valid pincode, hide out-of-stock product cards from grids, and make the header sticky on desktop + mobile. Display only; no rate/eligibility/MOV/checkout change. {%- endcomment -%}
  {{ 'ganguram-phase1-ux.css' | asset_url | stylesheet_tag }}

	{{ content_for_header }}

  <script>
    const rbi = [];
    const ribSetSize = (img) => {
      if ( img.offsetWidth / img.dataset.ratio < img.offsetHeight ) {
        img.setAttribute('sizes', `${Math.ceil(img.offsetHeight * img.dataset.ratio)}px`);
      } else {
        img.setAttribute('sizes', `${Math.ceil(img.offsetWidth)}px`);
      }
    }
    const debounce = (fn, wait) => {
      let t;
      return (...args) => {
        clearTimeout(t);
        t = setTimeout(() => fn.apply(this, args), wait);
      };
    }
    window.KEYCODES = {
      TAB: 9,
      ESC: 27,
      DOWN: 40,
      RIGHT: 39,
      UP: 38,
      LEFT: 37,
      RETURN: 13
    };
    window.addEventListener('resize', debounce(()=>{
      for ( let img of rbi ) {
        ribSetSize(img);
      }
    }, 250));
  </script>
	
  {%- if template == 'customers/addresses' or request.design_mode -%}
	  <script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer></script>
	{%- endif -%}

  <noscript>
    <link rel="stylesheet" href="{{ 'theme-noscript.css' | asset_url }}">
  </noscript>

</head>

<body id="{{ page_title | handle }}" class="no-touchevents 
  {% if customer %} customer-logged-in {% endif %} 
  template-{{ template.name }} template-{{ template | replace: '.', ' ' | handle }} 
  {% if settings.shadow_cards_x < 0 %} has-negative-shadow-x {% endif %}
  {% if settings.shadow_cards_y < 0 %} has-negative-shadow-y {% endif %}
  {% if settings.show_breadcrumb == false %} body--no-breadcrumb {% endif %}
  {% unless settings.show_sidebars_scrollbar %} sidebars-has-scrollbars {% endunless %}
">

  <script type="text/javascript">
    if ( 'ontouchstart' in window || window.DocumentTouch && document instanceof DocumentTouch ) { document.querySelector('body').classList.remove('no-touchevents'); document.querySelector('body').classList.add('touchevents'); } 
  </script>

  <a href="#main" class="visually-hidden skip-to-content" tabindex="0" data-js-inert>{{ 'general.accessibility_labels.skip_to_content' | t }}</a>
  <div id="screen-reader-info" aria-live="polite" class="visually-hidden"></div>

  <header>
    {{ 'section-header.css' | asset_url | stylesheet_tag }}
    {%- sections 'header-group' -%}
  </header>

  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-video.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'component-product-form.js' | asset_url }}" defer></script>

  <main id="main" class="main-content 
    {% if settings.product_card_align_buy %} main-content--align-product-items {% endif %}
  ">
    {%- render 'breadcrumb' -%}
    {{ content_for_layout }}
  </main>

  <footer>
    {%- sections 'footer-group' -%}
  </footer>

  {%- section 'popups' -%}
  {%- section 'popup-age-verification' -%}
  {%- section 'exit-intent-popup' -%}
  {%- section 'store-selector' -%}
  
  <script src="{{ 'component-modal.js' | asset_url }}" defer></script>
  <link rel="stylesheet" href="{{ 'component-modal.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-popup.css' | asset_url }}" media="print" onload="this.media='all'">

	<script type="text/javascript">

    KROWN = {
      themeName: "Local",
      themeVersion: "4.0.0",
      settings: {
        shop_money_format: '{{ shop.money_format | strip_html }}',
        iso_code: '{% if settings.show_currency_codes %} {{ localization.country.currency.iso_code }}{% endif %}',
        cart_action: "{{ settings.cart_action }}",
        google_maps_api_key: "{{ settings.google_maps_api_key | strip_html }}",
        google_maps_map_id: "{{ settings.google_maps_map_id | strip_html }}",
        routes: {
          cart_url: "{{ routes.cart_url }}",
          cart_add_url: "{{ routes.cart_add_url }}",
          cart_change_url: "{{ routes.cart_change_url }}",
          cart_update_url: "{{ routes.cart_update_url }}",
          predictive_search_url: "{{ routes.predictive_search_url }}",
          product_recommendations_url: "{{ routes.product_recommendations_url }}"
        },
        locales: {
          products_add_to_cart_button: `{{ 'products.page.add_to_cart_button' | t }}`,
          products_preorder_button: `{{ 'products.page.preorder_button' | t }}`,
          products_sold_out_variant: `{{ 'products.page.inventory.sold_out_variant' | t }}`,
          products_unavailable_variant: `{{ 'products.page.inventory.unavailable_variant' | t }}`, 
          products_variant_required: `{{ 'products.grid.choose_variant_first' | t }}`,
          products_one_product: `<span class="pill"><span class="pill__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'circle-time' -%}</span><span class="pill__text text-size--small">{{ 'products.page.inventory.one_product' | t }}</span></span>`,
          products_few_products: `<span class="pill"><span class="pill__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'circle-time' -%}</span><span class="pill__text text-size--small">{{ 'products.page.inventory.few_products' | t }}</span></span>`,
          products_many_products: `<span class="pill"><span class="pill__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'circle-checkmark' -%}</span><span class="pill__text text-size--small">{{ 'products.page.inventory.many_products' | t }}</span></span>`,
          products_no_products: `<span class="pill"><span class="pill__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'circle-exclamation' -%}</span><span class="pill__text text-size--small">{{ 'products.page.inventory.no_products' | t }}</span></span>`,
          products_preorder: `<span class="pill"><span class="pill__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'circle-exclamation' -%}</span><span class="pill__text text-size--small">{{ 'products.page.inventory.preorder' | t }}</span></span>`,
          products_enough_products: `<span class="pill"><span class="pill__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'circle-checkmark' -%}</span><span class="pill__text text-size--small">{{ 'products.page.inventory.enough_products' | t }}</span></span>`,
          cart_general_error: `{{ 'cart.general_error' | t }}`,
          cart_announcement: `{{ 'general.accessibility_labels.item_added' | t }}`,
          cart_discount_code_error: `<span class="alert alert--error text-size--small">{{ 'cart.discount_code_error' | t }}</span>`,
          store_selector_title_default: `{{ 'store_availability.store_selector.picking_up' | t }}`,
          store_selector_title_selected: `{{ 'store_availability.store_selector.my_store' | t }}`,
          store_selector_label: `{{ 'store_availability.store_selector.select_store_label' | t }}`,
          shipping_calculator_results_heading_one: `{{ 'cart.shipping_calculator.results_heading_one' | t }}`,
          shipping_calculator_results_heading_multiple: `{{ 'cart.shipping_calculator.results_heading_multiple' | t }}`,
          shipping_notice_remaining_to_free: `{{ 'cart.free_shipping_remaining_html' | t }}`,
          shipping_notice_eligible_for_free: `{{ 'cart.free_shipping_eligible' | t }}`,
          slider_next_button_label: `{{ 'general.accessibility_labels.next_slide' | t }}`,
          slider_prev_button_label: `{{ 'general.accessibility_labels.previous_slide' | t }}`,
          slider_thumbnail_label: `{{ 'general.accessibility_labels.slide' | t }}`
        },
        symbols: {
          zoom_out: `{%- render 'theme-symbols', icon: 'zoom-out' -%}`,
          zoom_loader: `<svg class="zoom__loader-element" viewBox="25 25 50 50"><circle cx="50" cy="50" r="20" fill="none" stroke-width="4"/></svg>`,
          close: `{%- render 'theme-symbols', icon: 'close' -%}`,
          toggle_pack: `<span class="toggle__icon">{%- render 'theme-symbols', icon: 'chevron' -%}</span>`,
          toggle_pack_alternate: `<span class="toggle__icon-alternate"><span class="toggle__icon--plus">{%- render 'theme-symbols', icon: 'plus' -%}</span><span class="toggle__icon--minus">{%- render 'theme-symbols', icon: 'minus' -%}</span></span>`
        },
        predictive_search_enabled: "true",
        predictive_search_script: "{{ 'component-predictive-search.js' | asset_url }}",
        predictive_search_placeholder: `<div class="search-results"><div class="search-block"><a class="search-item search-item--blank"><div class="thumbnail"></div><div class="content"><span class="title"></span><span class="caption"></span></div></a><a class="search-item search-item--blank"><div class="thumbnail"></div><div class="content"><span class="title"></span><span class="caption"></span></div></a><a class="search-item search-item--blank"><div class="thumbnail"></div><div class="content"><span class="title"></span><span class="caption"></span></div></a></div></div>`
      },
      functions: {
        eventDispatcher: (eventType, detail) => {
          document.dispatchEvent(new CustomEvent(eventType, {
            bubbles: true,
            detail: detail
          }));
        }
      }
    }
    
	</script>

  <script src="{{ 'component-quick-buy.js' | asset_url }}" defer></script>
  <script src="{{ 'component-pickup-availability.js' | asset_url }}" defer></script>

  <script src="{{ 'component-slider.js' | asset_url }}" defer></script>

  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer data-c="{{ shop.email }}" data-i="{{ shop.id }}" data-p="{{ settings.theme_preset }}"></script>
  {%- endif -%}
  
  {%- if settings.cart_action == "overlay" or template.name contains "cart" -%}

    <sidebar-drawer id="site-cart-sidebar" class="sidebar sidebar--right {% if cart.item_count == 0 %} cart-is-empty {% endif %}" tabindex="-1" role="dialog" aria-modal="true" aria-hidden="true" data-cart-items="{{ cart.item_count }}" style="display:none" data-js-site-cart-sidebar>
      
      <div class="sidebar__header">
        <span class="sidebar__title h5">
          {{ 'cart.title' | t }}
          (<span data-header-cart-count>{{ cart.item_count }}</span>)
        </span>
        <button class="sidebar__close" data-js-close>
          <span class="visually-hidden">{{ 'general.accessibility_labels.close_sidebar' | t }}</span>
          <span aria-hidden="true" aria-role="img">{%- render 'theme-symbols', icon: 'close' -%}</span>
        </button>
      </div>

      <div class="sidebar__body sidebar__body--flex">

        <div class="sidebar__body-top">
          <div class="cart-form">
            {%- render 'cart-form', type: 'sidebar' -%}
            <a href="{{ routes.all_products_collection_url }}" class="cart-continue button button--fullwidth button--solid button--regular">
              {{ 'cart.continue_browsing' | t }}
            </a>
          </div>

          {%- if settings.cart_recommendations -%}
            <cart-recommendations id="cart-recommendations" data-section="cart-recommendations" data-limit="6"></cart-recommendations>
            <script src="{{ 'component-cart-recommendations.js' | asset_url }}" defer></script>
          {%- endif -%}
        </div>

        {%- if settings.show_discount_code or settings.cart_notes_enable -%}

          <div class="sidebar__body-bottom hide-if-empty-cart">

            {%- if settings.cart_notes_enable -%}  
              <div class="cart__instructions cart-detail--collapsible-{{ settings.show_collapsible_notes_discount }}">

                {%- if settings.show_collapsible_notes_discount -%}
                  <details class="cart__accordion-details">
                    <summary class="align-content align-content--vertical-middle">
                      <span class="cart__accordion-title cart__note-title">
                        {{ 'cart.note' | t }}
                      </span>

                      <span class="cart__accordion-icon cart__note-icon" aria-hidden="true">
                        {%- render 'theme-symbols', icon: 'chevron' -%}
                      </span>
                    </summary>
                {%- endif -%}

                  <div class="form-field">
                    <cart-note>
                      <label for="CartDrawer-Note" class="{% if settings.show_collapsible_notes_discount %}visually-hidden{% endif %}">
                        {{ 'cart.note' | t }}
                      </label>
                      <textarea id="CartDrawer-Note" name="note">{{ cart.note }}</textarea>
                    </cart-note> 
                  </div>

                {%- if settings.show_collapsible_notes_discount -%}
                  </details>
                {%- endif -%}

              </div>
            {%- endif -%}
              
            {%- if settings.show_discount_code -%}
              <div class="cart-detail--collapsible-{{ settings.show_collapsible_notes_discount }}">
                
                {% liquid
                  assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
                  for item in cart.items
                    for allocation in item.line_level_discount_allocations
                      if allocation.discount_application.type == 'discount_code'
                        assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
                      endif
                    endfor
                  endfor

                  assign discount_codes = discount_codes | uniq
                %}
                
                {%- if settings.show_collapsible_notes_discount -%}
                  <details class="cart__accordion-details">
                    <summary class="align-content align-content--vertical-middle">
                      <span class="cart__accordion-title cart__discount-title">
                        {{ 'cart.discount_codes_label' | t }}
                      </span>

                      <span class="cart__accordion-icon cart__discount-icon" aria-hidden="true">
                        {%- render 'theme-symbols', icon: 'chevron' -%}
                      </span>
                    </summary>
                {%- endif -%}

                <div class="form-field">
                  <cart-discounts>
                    <label for="CartPage-Discount" class="{%- if settings.show_collapsible_notes_discount -%}visually-hidden{%- endif -%}">
                      {{ 'cart.discount_codes_label' | t }}
                    </label>

                    <form class="cart__coupons-form">
                      <input id="CartPage-Discount" name="discount" type="text" data-js-discount-input>
                      <button type="submit" id="cartDiscountSubmit" class="button button--small button--small-mobile button--solid" data-js-discount-submit>
                        {{ 'collections.apply' | t }}
                      </button>
                    </form>

                    {%- if settings.discount_text != blank -%}
                      <div class="cart__coupons-label text-size--small text-color--opacity">
                        {{ settings.discount_text | escape }}
                      </div>
                    {%- endif -%}

                    <div class="cart__coupons-error" data-js-discount-error></div>

                    <div class="cart__coupons-codes" data-js-discount-codes>
                      {%- for discount_code in discount_codes -%}
                        {%- render 'cart-item-discount', discount: discount_code, remove: true -%}
                      {%- endfor -%}
                    </div> 
                  </cart-discounts>
                </div>

                {%- if settings.show_collapsible_notes_discount -%}
                  </details>
                {%- endif -%}

              </div>
            {%- endif -%}

          </div>
          
        {%- endif -%}

      </div>
      
      {%- render 'cart-gift-wrapping', class: 'cart-wrapping--sidebar' -%}

      <div class="sidebar__footer hide-if-empty-cart" 
        {% if settings.sticky_cart_actions %} style="position: sticky;" {% endif %}
      >
        {%- render 'cart-subtotal', type: 'sidebar' -%}
      </div>

    </sidebar-drawer>

    <script>
      new MutationObserver((mutations, observer) => {
        if ( document.getElementById('cart').classList.contains('cart--empty') ) {
          document.getElementById('site-cart-sidebar').classList.add('cart-is-empty');
        } else {
          document.getElementById('site-cart-sidebar').classList.remove('cart-is-empty');
        }
      }).observe(document.querySelector('.cart-form'), {
        attributes: false, childList: true, subtree: true
      })
    </script>

  {%- elsif settings.cart_action == 'popup' -%}

    <sidebar-drawer id="site-cart-sidebar" class="sidebar sidebar--top" tabindex="-1" role="dialog" aria-modal="true" aria-hidden="true" data-js-site-cart-sidebar>
      
      <div class="sidebar__header">
        <span class="sidebar__title">
          {{ 'general.accessibility_labels.item_added' | t }}
        </span>
        <button class="sidebar__close" data-js-close>
          <span class="visually-hidden">{{ 'general.accessibility_labels.close_sidebar' | t }}</span>
          <span aria-hidden="true" aria-role="img">{%- render 'theme-symbols', icon: 'close' -%}</span>
        </button>
      </div>

      <div class="sidebar__body" data-js-site-cart-popup-content>
      </div>

      <div class="sidebar__footer">

        {%- if settings.cart_terms_checkbox -%}
          <terms-checkbox>
            <div class="agree-to-terms gutter-bottom--small">
              <input type="checkbox" id="AgreeToTos" class="styled-checkbox" required />
              <label for="AgreeToTos" class="text-size--small">
                {{ settings.cart_terms_text }}
              </label>
            </div>
          </terms-checkbox>
          <script src="{{ 'component-terms-checkbox.js' | asset_url }}" defer></script>
        {%- endif -%}
        
        <div class="flex-buttons">
          <a id="ViewCart" href="{{ routes.cart_url }}" class="button button--regular button--outline">{{ 'cart.view_cart' | t }}</a>
          <form action="{{ routes.cart_url }}" method="post" novalidate>
            <button id="CheckOut" class="button button--regular button--solid button--fullwidth" name="checkout" {%- if settings.cart_terms_checkbox -%} disabled {%- endif -%}>
              {{ 'cart.checkout' | t }}
            </button>
          </form>
        </div>
      </div>

    </sidebar-drawer>

  {%- endif -%}

  <link rel="stylesheet" href="{{ 'component-cart.css' | asset_url }}" media="print" onload="this.media='all'">

  <script src="{{ 'component-quantity-selector.js' | asset_url }}" defer></script>
  {%- if settings.cart_action == "overlay" or template.name contains "cart" -%}
    <script src="{{ 'component-cart.js' | asset_url }}" defer></script>
  {%- endif -%}

  <link rel="stylesheet" href="{{ 'component-sidebar.css' | asset_url }}" media="print" onload="this.media='all';">
  <script src="{{ 'section-header.js' | asset_url }}" defer></script>
  
  {%- if request.design_mode -%}
    <script src="{{ 'section-announcement-bar.js' | asset_url }}" defer></script>
    <script src="{{ 'component-toggle.js' | asset_url }}" defer></script>
    <script src="{{ 'section-main-product.js' | asset_url }}" defer></script>
    <script src="{{ 'component-video.js' | asset_url }}" defer></script>
    <script src="{{ 'component-store-selector.js' | asset_url }}" defer></script>
    <script src="{{ 'component-interactive-map.js' | asset_url }}" defer></script>
    <script src="{{ 'component-image-hotspots.js' | asset_url }}" defer></script>
    <script src="{{ 'component-localization-form.js' | asset_url }}" defer></script>
    <script src="{{ 'component-predictive-search.js' | asset_url }}" defer></script>
    <script src="{{ 'component-shipping-calculator.js' | asset_url }}" defer></script>
    <script src="{{ 'component-scrolling-text.js' | asset_url }}" defer></script>
    <script src="{{ 'component-before-after.js' | asset_url }}" defer></script>
    <script src="{{ 'component-collection-tabs.js' | asset_url }}" defer></script>
    <script src="{{ 'component-countdown-clock.js' | asset_url }}" defer></script>
    <script src="{{ 'component-share-link.js' | asset_url }}" defer></script>
  {%- endif -%}

  <div class="site-overlay" style="display:none"></div>

  <link rel="stylesheet" href="{{ 'section-main-product.css' | asset_url }}" media="print" onload="this.media='all';">

  {%- if settings.show_gotop -%}
    <span id="go-top" class="main-go-top"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    >
      <span class="visually-hidden">{{ 'general.accessibility_labels.go_to_top' | t }}</span>
      <span class="main-go-top__icon" aria-hidden="true">{%- render 'theme-symbols', icon: 'chevron' -%}</span>
    </span>
    <script>
      window.addEventListener('scroll', ()=>{
        if ( window.scrollY > 100 ) {
          document.getElementById('go-top').classList.add('show');
        } else {
          document.getElementById('go-top').classList.remove('show');
        }
      }, {passive: true});
    </script>
  {%- endif -%}
    
  <script>
    document.querySelectorAll('.rte a img').forEach(elm=>{
  		elm.parentNode.style.border = 'none';
    });
  </script>

  {%- unless template contains 'cart' and settings.enable_instapage == false -%}
    <script src="{{ 'instantpage.js' | asset_url }}" type="module" defer></script>
  {%- endunless -%}
    
    {%- if settings.disable_all_image_animations -%}
      <style>
        .lazy-image img,
        .lazy-image img:hover {
          transition: all 0ms !important;
          opacity: 1 !important;
          transform: none !important;
        }
        .no-touchevents a:hover .lazy-image.lazy-image--zoom-animation img,
        .no-touchevents .card--animation:hover .lazy-image.lazy-image--animation img  {
          top: 0;
          left: 0;
          height: 100%;
          width: 100%;
          object-fit: cover;
        }
      </style>
    {%- endif -%}

    {%- if template contains 'product' -%}
      <modal-box id="modal-common" class="popup-common" 
        data-options='{
          "show": 0,
          "showOnce": false,
          "enabled": false,
          "closeByKey": true,
          "disableScroll": true,
          "blockTabNavigation": true,
          "enableClose": true
        }'
        style="display:none;"
      ></modal-box>
    {%- endif -%}

  {%- comment -%} Delivery zone resolver (Phase 2.1a) — defines window.GanguramZone. No UI / cart / checkout / visibility logic. {%- endcomment -%}
  {%- render 'zone-resolver' -%}

  {%- comment -%} Customer-facing delivery location display labels (UI hotfix) — one helper (window.GanguramDisplayLabel) used by the header/popup/recent/cart for the visible label. Display only; internal zones/labels unchanged. Loaded after the resolver, before the UI modules that use it. {%- endcomment -%}
  <script src="{{ 'ganguram-display-label.js' | asset_url }}" defer></script>

  {%- comment -%} Delivering-to header widget (Phase 2.1b; CSS moved to <head> by hotfix to avoid icon FOUC) — UI only; loaded after the resolver. {%- endcomment -%}
  <script src="{{ 'ganguram-delivery-widget.js' | asset_url }}" defer></script>

  {%- comment -%} Mandatory pincode popup + add-to-cart/buy-now guard (Phase 2.1d) — UI/guard only via window.GanguramZone; no checkout/MOV/availability logic. {%- endcomment -%}
  {%- render 'delivery-location-popup' -%}
  {{ 'ganguram-delivery-popup.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'ganguram-delivery-popup.js' | asset_url }}" defer></script>

  {%- comment -%} Phase 1 storefront gate — no-pincode purchase gate only (HIDE Add to cart / Buy now and show an "Enter delivery pin code to shop" CTA). Out-of-stock hiding is done in Liquid (product.available) + CSS, NOT here. Loaded AFTER the resolver/popup. Display only; fail-open; no ShipZip/eligibility/MOV/prefill change. {%- endcomment -%}
  {%- comment -%} hideDynamicCheckout: hide the native product-page dynamic-checkout (Shop Pay etc.)
    button so a direct Buy-with-ShopPay can't bypass the pincode/address/method handoff. Customers
    use "Add to cart" / the custom "Buy now" (which run the GanguramCheckoutPrefill.prepareCheckout
    pipeline). Set to false to re-enable Shop Pay express on the product page (accepting that it skips
    the cart-side delivery handoff). {%- endcomment -%}
  <script>window.GanguramStorefrontGateConfig = { enabled: true, hideDynamicCheckout: true, ctaText: {{ 'Enter delivery pin code to shop' | json }} };</script>
  <script src="{{ 'ganguram-storefront-gate.js' | asset_url }}" defer></script>

  {%- comment -%} Saved delivery locations shell (Phase 2.8A) — recent guest locations + logged-in saved addresses; selection only, all via GanguramZone. No Google Maps / checkout autofill / filtering logic. {%- endcomment -%}
  <script src="{{ 'ganguram-saved-locations.js' | asset_url }}" defer></script>

  {%- comment -%} Google Places address search (Phase 2.9B) — optional pincode-finder in the popup; extracts a pincode and commits via GanguramZone.setSelectedPincode. Self-gates on a merchant key; Maps JS lazy-loads on popup open. No checkout autofill / filtering / cart logic. {%- endcomment -%}
  {%- render 'ganguram-places-address-search-config' -%}

  {%- comment -%} Shipping ESTIMATE mapping (Phase 2.11I) — pure, config-driven local slab + 4-hour radius mapping (window.GanguramEstimateConfig / GanguramShippingEstimate) used by the popup estimate and the pincode-area distance range. ESTIMATE/display only; ShipZip remains the final checkout rate. No ShipZip/service-code/MOV/eligibility/visibility/date-attr change. {%- endcomment -%}
  {%- render 'ganguram-shipping-estimate-config' -%}

  {%- comment -%} Driving-distance provider (Phase 2.11D) — for a SELECTED FULL ADDRESS, reuses the Phase 2.9B Google setup to compute the actual driving distance (confirmed distanceKm) used by the cart distance-slab rules. Needs the outlet origin setting + Distance Matrix API. Fail-open (no origin -> estimated pincode path). No checkout/shipping/SBZ/ShipZip/zipLogic/resolver/settings_data change. {%- endcomment -%}
  {%- render 'ganguram-distance-config' -%}

  {%- comment -%} Selected structured address store (Phase 2.11F.2) — window.GanguramAddress. Tracks whether a full Google address was SELECTED (vs pincode only), so the popup estimate + checkout prefill use the address basis even if a driving distance can't be computed. Display/handoff only; fail-open. No resolver/MOV/ShipZip/settings_data change. {%- endcomment -%}
  <script src="{{ 'ganguram-address.js' | asset_url }}" defer></script>

  {%- comment -%} Manual-pincode -> city enrichment (display hotfix) — when a selected pincode's city is unknown, asynchronously reuses the Phase 2.9B Google setup (no new key) to resolve the city and refresh the shared display label everywhere. Display/enrichment only; fail-open; Google not loaded on page load. No resolver/zone/filtering/cart-logic change. {%- endcomment -%}
  <script src="{{ 'ganguram-pincode-enrich.js' | asset_url }}" defer></script>

  {%- comment -%} Product visibility filtering by delivery zone (Phase 2.2) — display only; reads window.GanguramZone. No cart/checkout/menu/search/banner logic. {%- endcomment -%}
  {{ 'ganguram-product-zone-filter.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'ganguram-product-zone-filter.js' | asset_url }}" defer></script>

  {%- comment -%} Menu visibility by delivery zone (Phase 2.5) — display only; data-driven Kolkata-only collection map. No cart/checkout/ShipZip logic. {%- endcomment -%}
  {%- render 'ganguram-zone-visibility-config' -%}

  {%- comment -%} Admin-controlled "4 Hours Delivery" display (Phase 2.7) — menu/tile/collection visibility + time window + messages from theme settings. Display only; no checkout/shipping-rate/MOV/ShipZip logic. {%- endcomment -%}
  {%- render 'ganguram-4hour-delivery-config' -%}

  {%- comment -%} Cart eligibility enforcement on pincode change (Phase 2.7A) — reuses the zone eligibility rule; removes ineligible cart lines via the Ajax cart API and shows a message. No checkout/MOV/date-slot/shipping-rate/payment/ShipZip/SBZ/zipLogic logic. {%- endcomment -%}
  {%- render 'ganguram-cart-eligibility-config' -%}

  {%- comment -%} Custom Sweets Box cart grouping (Phase 2.12A) — brackets box lines (shared _ganguram_box_id) into one group card (header + slot badges + box total + remove-box) in the cart drawer/page. Display + safe grouped-remove only; Shopify owns prices. No ShipZip/resolver/MOV/date-picker change. {%- endcomment -%}
  {%- render 'ganguram-box-cart-group-config' -%}

  {%- comment -%} Empty collection warning + homepage redirect (Phase 2.7C) — collection pages only; reuses the product-zone filter output + GanguramZone. Display only; no checkout/shipping/ShipZip logic. {%- endcomment -%}
  {%- render 'ganguram-empty-collection-warning-config' -%}

  {%- comment -%} Product page pincode availability (Phase 2.7C hotfix) — product pages only; disables Add to Cart/Buy Now + message when the product is not deliverable to the selected pincode. Reuses the zone rule; no checkout/shipping/ShipZip logic. {%- endcomment -%}
  {%- render 'ganguram-product-availability-config' -%}

  {%- comment -%} Delivery location -> cart attributes handoff (Phase 2.10A) — mirrors the selected pincode/zone into Shopify cart attributes via the Ajax cart API for admin/order visibility. Reads GanguramZone only; fail-open. No checkout autofill, no MOV/date-slot/shipping/SBZ/ShipZip/zipLogic/payment, no eligibility/removal/undo change. {%- endcomment -%}
  {%- render 'ganguram-cart-attributes-config' -%}

  {%- comment -%} Delivery rule engine foundation (Phase 2.11B) — reads admin-configured rules from the `ganguram_delivery_rule` metaobject and resolves the rule for the selected pincode/zone (window.GanguramDeliveryRules). Data/resolver only; fail-open; NO UI/progress bar, NO MOV enforcement, NO checkout/charge/SBZ/ShipZip/zipLogic/resolver change. {%- endcomment -%}
  {%- render 'ganguram-delivery-rules-config' -%}

  {%- comment -%} Cart MOV resolver (distance-based slabs) — window.GanguramCartMov: the single MOV source of truth (rule MOV > distance slab > fallback) read by the cart progress bar AND the 4-Hour evaluator. Reuses GanguramShippingEstimate's distance + slab boundaries (loaded above). Display/advisory only; NO ShipZip rate / Standard-slab / service-code / eligibility / product-visibility / box-builder / discount change. {%- endcomment -%}
  {%- render 'ganguram-cart-mov-config' -%}

  {%- comment -%} Delivery message catalog (Phase 2.11E) — one customer-facing source of truth for delivery/pincode/MOV/mode messages (window.GanguramDeliveryMessages). THEME-side codes are shown in the cart; APP-side codes are owned here so the merchant can mirror them in ShipZip / the date-slot app. Display only; no checkout/shipping/SBZ/ShipZip/zipLogic/resolver/settings_data change. {%- endcomment -%}
  {%- render 'ganguram-delivery-messages-config' -%}

  {%- comment -%} Cart delivery progress + service options (Phase 2.11C / 2.11E) — ADVISORY cart UI: reads window.GanguramDeliveryRules (getProgressData/getServiceOptions) + the selected pincode/zone (primary source of truth) and paints accurate delivering-to / MOV / progress / charge / modes into the cart panel. Display only; fail-open; NO MOV enforcement, NO checkout/shipping-charge change, NO cart mutation, NO SBZ/ShipZip/zipLogic/Google/resolver change. {%- endcomment -%}
  {%- render 'ganguram-delivery-progress-config' -%}

  {%- comment -%} Local-delivery date picker (cart drawer + cart page) — theme-native date/time selector for local delivery (ShipZip's picker is cart-page-only and doesn't render in the drawer). Saves the selection as cart attributes and soft-blocks checkout until a required date is chosen. No ShipZip rate / service-code / MOV / pincode / product-visibility change. Display/handoff only; fail-open. {%- endcomment -%}
  {%- render 'ganguram-delivery-datepicker-config' -%}

  {%- comment -%} Persist cart delivery choice for checkout (Phase 2.12H) — mirrors the chosen delivery method (derived from the date-picker Standard/4 Hours toggle + the zone) into ganguram_preferred_delivery_method (STD/4HR/PAN_INDIA) + ganguram_preferred_delivery_label cart attributes, so a Delivery Customization (Shipzy rule / Shopify Function) can hide non-selected methods at checkout. Clears stale Standard date attrs for 4HR/PAN. No ShipZip rate/service-code/slab/eligibility/MOV/modal/box-builder change; merge-only; fail-open. {%- endcomment -%}
  {%- render 'ganguram-delivery-method-choice-config' -%}

  {%- comment -%} Product-card "Buy now" (Phase 2.11D.1) — adds an express Buy now next to Add to cart on single-variant product cards; reuses the theme AJAX add and proceeds to checkout ONLY if the cart-side MOV/checkout guard allows, else opens the cart drawer. Fail-open; NO checkout/shipping-charge/ShipZip/SBZ/zipLogic/resolver/settings_data change. {%- endcomment -%}
  {%- render 'ganguram-product-card-buy-config' -%}

  {%- comment -%} Checkout pincode mismatch warning (Phase 2.11E — Requirement B) — warns in the cart when the delivery-checker pincode (ganguram_selected_pincode) matches none of the logged-in customer's saved address pincodes. Warning only; never blocks checkout; fail-open (guest/no saved address -> nothing). The exact checkout-typed pincode needs a Checkout UI Extension (app). No checkout/shipping/ShipZip/SBZ/zipLogic/resolver/settings_data change. {%- endcomment -%}
  {%- render 'ganguram-pincode-mismatch-config' -%}

  {%- comment -%} Delivery estimate in the location popup (Phase 2.11F.1) — after a pincode/address resolves, renders status/city/distance/MOV/cart value/charge/modes into the popup ([data-ganguram-delivery-estimate]). Google distance is a SUPPORTING estimate (approximate for pincode-only); ShipZip/zone rules stay the source of truth. Display only; fail-open. No checkout/shipping/ShipZip/SBZ/zipLogic/resolver/settings_data change. {%- endcomment -%}
  {%- render 'ganguram-delivery-estimate-config' -%}

  {%- comment -%} Checkout shipping-address prefill (Phase 2.11F.2) — when a full Google address was selected in the popup, appends checkout[shipping_address][...] params to the STANDARD checkout URL so Shopify prefills the shipping address. Standard button only (not Shop Pay/dynamic); respects the MOV guard; preserves cart/attributes/discounts/payment; fail-open. No checkout/shipping-rate/ShipZip/SBZ/zipLogic/resolver/settings_data change. {%- endcomment -%}
  {%- render 'ganguram-checkout-prefill-config' -%}

</body>
</html>