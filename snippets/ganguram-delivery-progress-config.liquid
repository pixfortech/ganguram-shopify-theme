{%- comment -%}
  Ganguram — Cart delivery progress + MOV checkout-guard config (Phase 2.11C / 2.11C.1).

  Publishes window.GanguramDeliveryProgressConfig (display copy) and loads the
  advisory cart UI (assets/ganguram-delivery-progress.js + .css). The UI reads
  window.GanguramDeliveryRules (getProgressData / getServiceOptions) and updates,
  from one shared state: the cart progress/MOV panel, a notice near the checkout
  button, and a soft checkout guard (intercept when below the minimum order value).

  ADVISORY / CART-SIDE ONLY: no Shopify checkout change, no final shipping-charge
  change, no cart mutation, no ShipZip/SBZ/zipLogic/Google/resolver change, no
  settings_data.json. Fail-open (no rules / no selection / no MOV -> nothing blocked).

  Copy uses Liquid-SAFE tokens __MOV__ / __SUBTOTAL__ / __REMAINING__ / __AMOUNT__ /
  __DATE__. A single-brace placeholder token must NOT appear inside a Liquid output
  tag — Shopify's Liquid parser treats the inner brace as a tag start and fails the
  import. The JS replaces these tokens at runtime.
{%- endcomment -%}
<script>
  window.GanguramDeliveryProgressConfig = {
    enabled: true,
    copy: {
      movLabel: {{ 'Minimum order:' | json }},
      deliveringTo: {{ 'Delivering to __LABEL__' | json }},
      chargeAtCheckout: {{ 'Final delivery charge will be confirmed at checkout.' | json }},
      fourHourIneligible: {{ '4-hour delivery is not available because the following item(s) are not eligible for quick delivery: __ITEMS__' | json }},
      cartValueLabel: {{ 'Cart value:' | json }},
      addMore: {{ 'Add __REMAINING__ more to reach the minimum order for __PINCODE__' | json }},
      minReached: {{ 'Minimum order reached for __PINCODE__' | json }},
      checkoutNotice: {{ 'Minimum order value for your area is __MOV__. Please add __REMAINING__ more to continue.' | json }},
      freeDeliveryHint: {{ 'add __AMOUNT__ for free delivery' | json }},
      freeDelivery: {{ 'Free delivery' | json }},
      deliveryChargeFrom: {{ 'Delivery from __AMOUNT__' | json }},
      datePickerNote: {{ 'Choose a delivery date' | json }},
      earliestNote: {{ 'earliest __DATE__' | json }},
      standardLabel: {{ 'Standard delivery' | json }},
      fourHourLabel: {{ '4-hour delivery' | json }}
    }
  };
</script>
{{ 'ganguram-delivery-progress.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ganguram-delivery-progress.js' | asset_url }}" defer></script>
