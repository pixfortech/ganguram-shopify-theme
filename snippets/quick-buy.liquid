{%- comment -%}
  Renders a quick buy button for a product card.

  Accepts:
  - product: {Object} the product object.
  - button_classes: {String} additional classes to add to the button element.

  Usage:
  {% render 'quick-buy', product: product, button_classes: 'button--small', quick_buy_button_text: block.settings.quick_buy_text, choose_options_button_text: block.settings.choose_options_text %}
{%- endcomment -%}

{%- unless product.available -%}

  <button class="button button--{{ settings.product_card_button_style }} {{ button_classes }}" disabled
    style="pointer-events: none; opacity: 0.36; {% if quick_buy_minimal == true %}display: none{% endif %}"
  >
    <span class="button__text {% if layout == 'shop' %} text-size--regular {% endif %}">{{ 'products.grid.sold_out_product' | t }}</span>
  </button>

{%- else -%}

  {%- if product.has_only_default_variant and settings.product_card_quick_buy_always_show_modal == false -%}
    <quick-add-to-cart class="quick-add-to-cart {% if quick_buy_minimal == true %}quick-add-to-cart--minimal{% endif %}{% if show_buy_now %} ganguram-card-buy{% endif %}" data-js-product-component>
      <product-form {% unless settings.cart_action == 'no-overlay' %} data-ajax-cart {% endunless %} data-product-url="{{ product.url }}">
        <div class="quick-add-to-cart-button{% if show_buy_now %} ganguram-card-buy__buttons{% endif %}">
          {%- form 'product', product -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button class="button button--{{ settings.product_card_button_style }} {{ button_classes }} button--loader" data-js-product-add-to-cart type="submit" name="add">
              {%- liquid
                # Ganguram (Phase 2.11D.1): on product cards (show_buy_now) the primary
                # button is "Add to cart"; a sibling "Buy now" button is added below.
                # Every other quick-buy usage is unchanged.
                assign default_button_text = 'products.grid.quick_buy' | t
                if show_buy_now
                  assign default_button_text = 'products.page.add_to_cart_button' | t
                endif
                assign quick_buy_button_text = quick_buy_button_text | default: default_button_text
              -%}
              <span class="button__text {% if layout == 'shop' %} text-size--regular {% endif %} {% if quick_buy_minimal == true %}visually-hidden{% endif %}">{{ quick_buy_button_text }}</span>

              {%- if quick_buy_minimal == true -%}
                <span class="quick-buy-button__minimal">
                  {%- render 'theme-symbols', icon: 'plus' -%}
                </span>
              {%- endif -%}

              <span class="button__preloader">
                <svg class="button__preloader-element" viewBox="25 25 50 50"><circle cx="50" cy="50" r="20" fill="none" stroke-width="4"/></svg>
              </span>
            </button>

            {%- comment -%} Ganguram Buy now — adds, then proceeds to checkout ONLY if the cart-side MOV/checkout guard allows (else opens the cart drawer). Handled by ganguram-product-card-buy.js. Fail-open. {%- endcomment -%}
            {%- if show_buy_now -%}
              <button class="button button--{{ settings.product_card_button_style }} button--outline {{ button_classes }} ganguram-buy-now" type="button" data-ganguram-buy-now>
                <span class="button__text {% if layout == 'shop' %} text-size--regular {% endif %}">{{ 'products.grid.quick_buy' | t }}</span>
              </button>
            {%- endif -%}
          {%- endform -%}
        </div>
      </product-form>
    </quick-add-to-cart>
  {%- else -%}
    <quick-view-product class="quick-add-to-cart {% if quick_buy_minimal == true %}quick-add-to-cart--minimal{% endif %}">
      <a href="{{ product.url }}" class="button button--{{ settings.product_card_button_style }} {{ button_classes }} button--loader" data-js-product-add-to-cart data-id="{{ product.id }}">
        <span class="button__text {% if layout == 'shop' %} text-size--regular {% endif %} {% if quick_buy_minimal == true %}visually-hidden{% endif %}">
          {%- liquid
            if settings.product_card_buy_button_labels == 'buy_now'
              assign default_button_text = 'products.grid.quick_buy' | t
              echo quick_buy_button_text | default: default_button_text
            else 
              assign default_button_text = 'products.page.choose_options_button' | t
              echo choose_options_button_text | default: default_button_text
            endif
          -%}
        </span>

        {%- if quick_buy_minimal == true -%}
          <span class="quick-buy-button__minimal">
            {%- render 'theme-symbols', icon: 'plus' -%}
          </span>
        {%- endif -%}

        <span class="button__preloader">
          <svg class="button__preloader-element" viewBox="25 25 50 50"><circle cx="50" cy="50" r="20" fill="none" stroke-width="4"/></svg>
        </span>
      </a>
    </quick-view-product>
  {%- endif -%}

{%- endunless -%}