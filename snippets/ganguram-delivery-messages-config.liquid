{%- comment -%}
  Ganguram — Delivery message catalog config (Phase 2.11E).

  Publishes window.GanguramDeliveryMessagesConfig (the customer-facing delivery /
  pincode / MOV / mode messages) and loads assets/ganguram-delivery-messages.js
  (window.GanguramDeliveryMessages.get(code, vars)). One source of truth so the
  cart, popup and any future surface speak with one voice.

  THEME-SIDE codes are shown early in the cart (the theme can detect them).
  APP-SIDE codes (CHARGE_UNAVAILABLE, WEIGHT_EXCEEDED, NO_STANDARD_RATE,
  NO_FOUR_HOUR_RATE, DATE_NOT_SELECTED, SLOT_NOT_SELECTED, SLOT_EXPIRED,
  APP_FAILURE) can only be known at Shopify checkout / inside ShipZip / the
  date-slot app — the theme cannot enforce them, but it OWNS the wording so the
  merchant can mirror it there. See docs/delivery-rule-engine-admin-setup.md §6.

  Display only. Liquid-SAFE tokens __MOV__ / __REMAINING__ / __PINCODE__ / __ITEMS__
  (a single-brace token would break Shopify's Liquid parser inside an output tag);
  the JS replaces them at runtime.
{%- endcomment -%}
<script>
  window.GanguramDeliveryMessagesConfig = {
    messages: {
      NO_PINCODE: {{ 'Please enter your delivery pincode to check delivery availability.' | json }},
      INVALID_PINCODE: {{ 'Please enter a valid 6-digit Indian pincode.' | json }},
      NOT_SERVICEABLE: {{ 'Sorry, we currently do not deliver to this pincode.' | json }},
      ADDRESS_INCOMPLETE: {{ 'Please enter your complete delivery address to calculate accurate delivery options.' | json }},
      PINCODE_CITY_MISMATCH: {{ 'The selected city/state does not match the entered pincode. Please check your address.' | json }},
      MOV_NOT_REACHED: {{ 'Minimum order value for your area is __MOV__. Please add __REMAINING__ more to continue.' | json }},
      CHARGE_UNAVAILABLE: {{ 'Delivery charge could not be calculated for this address. Please check your pincode or try again.' | json }},
      WEIGHT_EXCEEDED: {{ 'This order exceeds the available delivery weight limit for your area. Please reduce quantity or contact us.' | json }},
      QC_NOT_AVAILABLE: {{ '4 Hours Delivery is not available for this pincode. Standard delivery may still be available.' | json }},
      MIXED_CART: {{ '4 Hours Delivery is available only when all items in the cart are Quick-Commerce eligible.' | json }},
      MIXED_CART_ITEMS: {{ '4 Hours Delivery is not available because the following item(s) are not eligible for quick delivery: __ITEMS__' | json }},
      PRODUCT_NOT_LOCAL: {{ 'One or more products in your cart are not available for delivery to this pincode.' | json }},
      PRODUCT_NOT_PAN_INDIA: {{ 'One or more fresh/local items in your cart cannot be shipped outside Kolkata.' | json }},
      NO_STANDARD_RATE: {{ 'Standard delivery is currently unavailable for this cart/address. Please check your address or contact us.' | json }},
      NO_FOUR_HOUR_RATE: {{ '4 Hours Delivery is currently unavailable. Please choose Standard Delivery.' | json }},
      DATE_NOT_SELECTED: {{ 'Please select a delivery date before placing the order.' | json }},
      SLOT_NOT_SELECTED: {{ 'Please select a delivery time slot before placing the order.' | json }},
      SLOT_EXPIRED: {{ 'This delivery slot is no longer available. Please choose another slot.' | json }},
      APP_FAILURE: {{ 'We could not load delivery options at the moment. Please refresh and try again.' | json }},
      CHECKOUT_PINCODE_MISMATCH: {{ 'The delivery pincode entered at checkout is different from the pincode used to calculate your cart delivery options. Please recheck the pincode to ensure accurate availability, delivery charges, and delivery timing.' | json }},
      CHECKOUT_PINCODE_MISMATCH_SHORT: {{ 'Your checkout pincode is different from the pincode used in the delivery checker. Please recheck it to avoid incorrect delivery charges or delivery issues.' | json }}
    }
  };
</script>
<script src="{{ 'ganguram-delivery-messages.js' | asset_url }}" defer></script>
