{%- comment -%}
  Ganguram — cart delivery progress + MOV panel (Phase 2.11C / 2.11C.1).

  Read-only markup, rendered at the top of the cart (drawer + page) when the cart
  has items. Populated client-side by assets/ganguram-delivery-progress.js from
  window.GanguramDeliveryRules + the selected location. Starts hidden; shows only
  when an admin delivery rule resolves. data-gdpr-cart-total carries the live cart
  total in PAISE (re-rendered on cart updates). Display/advisory only.

  Accepts: context = 'drawer' (compact) | 'page' (detailed). The minimum-order /
  cart-value lines are shown only in the detailed (page) layout via CSS.
{%- endcomment -%}
{%- assign gdpr_context = context | default: 'drawer' -%}
<div class="ganguram-delivery-progress ganguram-delivery-progress--{{ gdpr_context }}" data-ganguram-delivery-progress data-gdpr-cart-total="{{ cart.total_price }}" data-gdpr-context="{{ gdpr_context }}" hidden>
  <div class="ganguram-delivery-progress__lines" data-gdpr-lines hidden>
    <span class="ganguram-delivery-progress__line" data-gdpr-mov-line hidden>
      <span class="ganguram-delivery-progress__line-label" data-gdpr-mov-label></span>
      <span class="ganguram-delivery-progress__line-value" data-gdpr-mov></span>
    </span>
    <span class="ganguram-delivery-progress__line" data-gdpr-subtotal-line hidden>
      <span class="ganguram-delivery-progress__line-label" data-gdpr-subtotal-label></span>
      <span class="ganguram-delivery-progress__line-value" data-gdpr-subtotal></span>
    </span>
  </div>
  <p class="ganguram-delivery-progress__message" data-gdpr-message hidden></p>
  <div class="ganguram-delivery-progress__bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" data-gdpr-bar hidden>
    <div class="ganguram-delivery-progress__bar-fill" data-gdpr-bar-fill></div>
  </div>
  <p class="ganguram-delivery-progress__charge" data-gdpr-charge hidden></p>
  <ul class="ganguram-delivery-progress__services" data-gdpr-services hidden></ul>
</div>
