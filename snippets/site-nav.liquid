{%- comment -%}
	Renders the site navigation.
	
	Accepts:
	- linklist: {String} the linklist object.
	- type: {String} the navigation type (can be "classic" or "sidebar").
	- blocks: {array} the blocks object array (for the promotional blocks).
	
	Usage:
	{% render 'site-nav', linklist: 'main-menu', type: 'classic', blocks: section.blocks %}
{%- endcomment -%}

{%- liquid
	if type == "classic" 
		assign links_class = "text-animation--underline-in-header"
	endif 
-%}

{%- comment -%} Phase 1 (visual only): hover/tap animation scoped to the "Mango Delights" menu item. CSS-only, no JS, no business logic. Emitted once on the classic pass; styles apply to desktop + mobile drawer. {%- endcomment -%}
{%- if type == 'classic' -%}
	{% style %}
		.menu-link.menu-item--mango {
			--mango-light: #ffce7a;
			--mango-deep: #ef7d1a;
			--mango-text: #7c3f12;
			position: relative;
			isolation: isolate;
			transition: transform .25s cubic-bezier(.2,.7,.3,1.4), color .2s ease;
		}
		/* glossy ripe-mango chip — centred & height-bound so it stays inside the menu row (no header bleed) */
		.menu-link.menu-item--mango::before {
			content: "";
			position: absolute;
			inset-inline: 8px;
			top: 50%;
			height: 1.85em;
			margin-top: -0.925em;
			z-index: -1;
			border-radius: 999px;
			background:
				linear-gradient(180deg, rgba(255,255,255,.32), rgba(255,255,255,0) 52%),
				linear-gradient(135deg, var(--mango-light), var(--mango-deep));
			opacity: 0;
			transform: scale(.92);
			transition: opacity .2s ease, transform .25s cubic-bezier(.2,.7,.3,1.4), box-shadow .2s ease;
		}
		/* recolour the theme underline (it uses --color-accent-header) to mango */
		.menu-link.menu-item--mango .text-animation--underline-in-header {
			background-image: linear-gradient(to right, var(--mango-deep), var(--mango-deep));
		}
		/* hover: deep mango-brown text + gentle lift + soft warm glow on the chip */
		.no-touchevents .menu-link.menu-item--mango:hover {
			color: var(--mango-text);
			transform: translateY(-1px);
		}
		.no-touchevents .menu-link.menu-item--mango:hover::before {
			opacity: 1;
			transform: scale(1);
			box-shadow: 0 4px 12px -5px rgba(239,125,26,.55), inset 0 1px 0 rgba(255,255,255,.45);
		}
		/* active / tap: subtle pop only */
		.menu-link.menu-item--mango:active { animation: mango-pop .32s cubic-bezier(.2,.7,.3,1.4); }
		.menu-link.menu-item--mango:active::before { opacity: 1; transform: scale(1); }
		@keyframes mango-pop {
			0%   { transform: scale(1); }
			45%  { transform: scale(1.05); }
			100% { transform: scale(1); }
		}
		@media (prefers-reduced-motion: reduce) {
			.menu-link.menu-item--mango,
			.menu-link.menu-item--mango::before,
			.menu-link.menu-item--mango:hover,
			.menu-link.menu-item--mango:active {
				transition: none !important;
				animation: none !important;
				transform: none !important;
			}
		}
	{% endstyle %}
{%- endif -%}

<div class="site-nav style--{{ type }}">

	<div class="site-nav-container">

		<nav>

			{%- assign mega_menus = false -%}

			<ul class="link-list">

				{%- for link in linklists[linklist].links -%}

					{%- liquid
						assign link_is_mega_menu = false
						assign promotion_block = false
						assign promotion_block_2 = false
					-%}

					{%- for block in blocks -%}
						
						{%- if block.type == 'mega-menu' and block.settings.menu_handle == link.handle -%}
							
							{%- assign link_is_mega_menu = true -%}
							{%- assign link_is_mega_menu_with_images = block.settings.show_menu_images -%}
							{%- assign link_columns = block.settings.link_columns -%}
							{%- assign mega_menus = true -%}

							{%- if block.settings.show_promotion_block -%}

								{%- assign promotion_block = true -%}

								{%- capture promotion_block -%}

									<li class="mega-link has-promotion">
 
										<div class="menu-promotion align-content--vertical-middle align-content--horizontal-center gutter--regular element--border-radius" data-id="{{ block.id }}">

											<div class="menu-promotion-content align-content gutter--regular spacing--large remove-empty-space">

												{%- if block.settings.promotion_title != blank -%}
													<span class="menu-promotion-title">
														<span class="{{ block.settings.promotion_title_size }} text-weight--bold text-line-height--small">{{ block.settings.promotion_title | escape }}</span>
													</span>
												{%- endif -%}

												{%- if block.settings.promotion_subtitle != blank -%}
													<span class="menu-promotion-subtitle {{ block.settings.promotion_subtitle_size }}">{{ block.settings.promotion_subtitle | escape }}</span>
												{%- endif -%}

												{%- if block.settings.promotion_button_label != blank -%}
													<a title="{{ block.settings.promotion_button_label | escape }}" class="menu-promotion-button button button--regular button--solid no-focus-link" href="{{ block.settings.promotion_button_link | escape }}">
														{{ block.settings.promotion_button_label | escape }}
													</a>
												{%- endif -%}
												
											</div>
					
											{%- unless block.settings.promotion_image == blank -%}
												<div class="menu-promotion-background-image">
													{%- assign image = block.settings.promotion_image -%}
													<img
														src="{{ image | image_url: width: 240 }}" alt="{{ image.alt | escape }}"
														srcset="{{ image | image_url: width: 240 }} 180w, {{ image | image_url: width: 360 }} 300w, {{ image | image_url: width: 600 }} 480w, {{ image | image_url: width: 860 }} 720w"
														sizes="380px"
														width="{{ image.width }}" height="{{ image.height }}"
														loading="lazy" 
													/>
												</div>
											{%- endunless -%}

										</div>

										<style type="text/css">
											{%- liquid
												assign color_text_brightness = block.settings.promotion_color_txt | color_brightness
												if color_text_brightness > 150
													assign color_text_foreground = settings.color_foreground_light
												else
													assign color_text_foreground = settings.color_foreground_dark
												endif
											-%}
											.menu-promotion[data-id="{{ block.id }}"] {
												color: {{ block.settings.promotion_color_txt }};
											}
											.menu-promotion[data-id="{{ block.id }}"] .menu-promotion-button {
												color: {{ color_text_foreground }} !important;
												background: {{ block.settings.promotion_color_txt }} !important;
											}
											.menu-promotion[data-id="{{ block.id }}"] .menu-promotion-button:hover {
												background: {{ color_text_foreground }} !important;
												color: {{ block.settings.promotion_color_txt }} !important;
											}
											{%- if block.settings.promotion_image == blank -%}
												.menu-promotion[data-id="{{ block.id }}"] {
													background: {{ block.settings.promotion_color_bg }};
												}
											{%- else -%}
												.menu-promotion[data-id="{{ block.id }}"] .menu-promotion-background-image:after {
													background: {{ block.settings.promotion_color_bg }};
												}
											{%- endif -%}
										</style>
										
									</li>

								{%- endcapture -%}

							{%- endif -%}

							{%- if block.settings.show_promotion_block_2 -%}

								{%- assign promotion_block_2 = true -%}

								{%- capture promotion_block_2 -%}

									<li class="mega-link has-promotion">
 
										<div class="menu-promotion align-content--vertical-middle align-content--horizontal-center gutter--regular element--border-radius" data-id="{{ block.id }}-2">

											<div class="menu-promotion-content align-content gutter--regular spacing--large remove-empty-space">

												{%- if block.settings.promotion_title_2 != blank -%}
													<span class="menu-promotion-title">
														<span class="{{ block.settings.promotion_title_size_2 }} text-weight--bold text-line-height--small">{{ block.settings.promotion_title_2 | escape }}</span>
													</span>
												{%- endif -%}

												{%- if block.settings.promotion_subtitle_2 != blank -%}
													<span class="menu-promotion-subtitle {{ block.settings.promotion_subtitle_size_2 }}">{{ block.settings.promotion_subtitle_2 | escape }}</span>
												{%- endif -%}

												{%- if block.settings.promotion_button_label_2 != blank -%}
													<a title="{{ block.settings.promotion_button_label_2 | escape }}" class="menu-promotion-button button button--regular button--solid no-focus-link" href="{{ block.settings.promotion_button_link_2 | escape }}">
														{{ block.settings.promotion_button_label_2 | escape }}
													</a>
												{%- endif -%}
												
											</div>
					
											{%- unless block.settings.promotion_image_2 == blank -%}
												<div class="menu-promotion-background-image">
													{%- assign image = block.settings.promotion_image_2 -%}
													<img
														src="{{ image | image_url: width: 240 }}" alt="{{ image.alt | escape }}"
														srcset="{{ image | image_url: width: 240 }} 180w, {{ image | image_url: width: 360 }} 300w, {{ image | image_url: width: 600 }} 480w, {{ image | image_url: width: 860 }} 720w"
														sizes="380px"
														width="{{ image.width }}" height="{{ image.height }}"
														loading="lazy" 
													/>
												</div>
											{%- endunless -%}

										</div>

										<style type="text/css">
											{%- liquid
												assign color_text_brightness_2 = block.settings.promotion_color_txt_2 | color_brightness
												if color_text_brightness_2 > 150
													assign color_text_foreground_2 = settings.color_foreground_light
												else
													assign color_text_foreground_2 = settings.color_foreground_dark
												endif
											-%}
											.menu-promotion[data-id="{{ block.id }}-2"] {
												color: {{ block.settings.promotion_color_txt_2 }};
											}
											.menu-promotion[data-id="{{ block.id }}-2"] .menu-promotion-button {
												color: {{ color_text_foreground_2 }} !important;
												background: {{ block.settings.promotion_color_txt_2 }} !important;
											}
											.menu-promotion[data-id="{{ block.id }}-2"] .menu-promotion-button:hover {
												background: {{ color_text_foreground_2 }} !important;
												color: {{ block.settings.promotion_color_txt_2 }} !important;
											}
											{%- if block.settings.promotion_image_2 == blank -%}
												.menu-promotion[data-id="{{ block.id }}-2"] {
													background: {{ block.settings.promotion_color_bg_2 }};
												}
											{%- else -%}
												.menu-promotion[data-id="{{ block.id }}-2"] .menu-promotion-background-image:after {
													background: {{ block.settings.promotion_color_bg_2 }};
												}
											{%- endif -%}
										</style>
										
									</li>

								{%- endcapture -%}

							{%- endif -%}
						
						{%- endif -%}
					{%- endfor -%}

					<li 
						{% if link.links != blank %}
							class="has-submenu" 
						{% elsif link_is_mega_menu %}
							class="has-submenu submenu-is-mega-menu"
						{% endif %} 
						id="menu-item-{{ link.handle }}"
					>

						<a 
							class="menu-link {% if link.active or link.child_active %} active {% endif %} {% unless link.links != blank or link_is_mega_menu %} no-focus-link {% endunless %}{% assign menu_key = link.title | handleize %}{% if menu_key == 'mango-delights' %} menu-item--mango{% endif %}"
							href="{{ link.url }}"
							{% if link_is_mega_menu or link.links != blank %}
								aria-controls="SiteNavLabel-{{ link.handle }}-{{ type }}" aria-expanded="false" aria-haspopup="true"
							{% endif %}
						>

							<span><span class="{{ links_class }}">{{ link.title | escape }}</span></span>

							{% if link.links != blank or link_is_mega_menu %}
								<span class="icon">{%- render 'theme-symbols', icon: 'chevron' -%}</span>
							{% endif %}

						</a>

						{% if link.links != blank or link_is_mega_menu %}

							<ul 
								class="submenu {% if link_is_mega_menu %} mega-menu {% else %} normal-menu {% endif %}" 
								id="SiteNavLabel-{{ link.handle }}-{{ type }}"
							>

								<div class="submenu-holder {% if link_is_mega_menu and type == 'classic' %} container--large gutter--regular {% endif %}">

									{%- if link_is_mega_menu -%}
										<div class="submenu-masonry {% if promotion_block and promotion_block_2 %} with-promotion with-2-promotions {% elsif promotion_block or promotion_block_2 %} with-promotion {% else %} without-promotion {% endif %}" {% if link_columns %}data-columns="{{ link_columns }}"{% endif %}>
									{%- endif -%}

									{%- if type == 'sidebar' -%}
										<li class="submenu-back">
											<a><span class="icon">{%- render 'theme-symbols', icon: 'chevron' -%}</span>{{ 'general.accessibility_labels.back' | t }}</a>
										</li>
									{%- endif -%}

										{%- for childlink in link.links -%}

											<li 
												{% if link_is_mega_menu %} 
													class="mega-link {% if childlink.links != blank %} has-babymenu {% endif %}"
												{% elsif childlink.links != blank %}
													class="has-babymenu"
												{% endif %}
											>

												{%- if link_is_mega_menu and link_is_mega_menu_with_images -%}
													{%- liquid
														assign image_name = childlink.handle | append: '.jpg'
														assign image = images[image_name]
														if image == blank
															assign image_name = childlink.handle | append: '.webp'
															assign image = images[image_name]
														endif
													-%}
													{%- if image != blank -%}
														<a href="{{ childlink.url }}" title="{{ childlink.title | escape }}" class="mega-image element--border-radius margin-bottom--regular">
															{%- render 'lazy-image', image: image, sizes: '(max-width: 479px) 100vw, (max-width: 1280px) 420px, (max-width: 1380px) 25vw, 380px', alt: childlink.title, class: 'lazy-image--animation' -%}
														</a>
													{%- endif -%}
												{%- endif -%}

												<a class="menu-link {% if link_is_mega_menu == false and childlink.active or childlink.child_active %} active {% endif %} {% unless childlink.links != blank %} no-focus-link {% endunless %}{% assign menu_key = childlink.title | handleize %}{% if menu_key == 'mango-delights' %} menu-item--mango{% endif %}"
													href="{{ childlink.url }}"
													{% if link_is_mega_menu or childlink.links != blank  %}
														aria-controls="SiteNavLabel-{{ childlink.handle }}-{{ type }}" aria-expanded="false" aria-haspopup="true"
													{% endif %}
												>
													<span><span class="{{ links_class }}">{{ childlink.title | escape }}</span></span>
													{%- if childlink.links != blank -%}
														<span class="icon">{%- render 'theme-symbols', icon: 'chevron' -%}</span>
													{%- endif -%}
												</a>

												{%- if childlink.links != blank -%}

													<div class="babymenu">
														<ul 
															id="SiteNavLabel-{{ childlink.handle }}-{{ type }}"
														>

															{%- if type == 'sidebar' -%}
																<li class="submenu-back">
																	<a><span class="icon">{%- render 'theme-symbols', icon: 'chevron' -%}</span>{{ 'general.accessibility_labels.back' | t }}</a>
																</li>
															{%- endif -%}

															{% for babylink in childlink.links %}
																<li><a title="{{ babylink.title | escape }}" class="menu-link {% if babylink.active %} active {% endif %} no-focus-link{% assign menu_key = babylink.title | handleize %}{% if menu_key == 'mango-delights' %} menu-item--mango{% endif %}" href="{{ babylink.url }}"><span><span class="{{ links_class }}">{{ babylink.title | escape }}</span></span></a></li>
															{% endfor %}

														</ul>

														{%- if image != blank -%}
															<div class="baby-image element--border-radius margin-bottom--regular">
																{%- render 'lazy-image', image: image, sizes: '(max-width: 479px) 100vw,(max-width: 1280px) 420px, (max-width: 1380px) 25vw, 380px', alt: childlink.title -%}
															</div>
														{%- endif -%}

													</div>

												{%- endif -%}

											</li>

										{%- endfor -%}

									{%- if link_is_mega_menu -%}
										</div>
									{%- endif -%}

								{%- liquid
									if promotion_block
										echo promotion_block
									endif
									if promotion_block_2
										echo promotion_block_2
									endif
								-%}

								</div>

							</ul>

						{% endif %}

					</li>

				{%- endfor -%}

				<!--{%- if type == 'sidebar' and shop.customer_accounts_enabled -%}
					<li id="menu-item-account">
						<a class="menu-link" href="{%- liquid
							if customer
								echo routes.account_url
							else
							 echo routes.account_login_url
							endif
						-%}" title="{{ 'general.breadcrumb.account' | t }}">
							<span style="display: inline-flex; align-items: center;">
								<span aria-hidden="true" style="display:flex; margin-inline-end:6px;">{%- render 'theme-symbols', icon: 'account' -%}</span>
								{{ 'general.breadcrumb.account' | t }}
							</span>
						</a>
					</li>
				{%- endif -%}-->

			</ul>

			{%- if mega_menus and type == 'classic' -%}
				<script src="{{ 'vendor-macy.js' | asset_url }}" defer onload="runMacy()"></script>
				<script>
					function runMacy(){
						document.querySelectorAll('.site-nav.style--classic .submenu-masonry').forEach(elm=>{
							let columns = 4;
							if ( elm.classList.contains('with-2-promotions') ) {
								columns = 2;
							} else if ( elm.classList.contains('with-promotion') ) {
								columns = 3;
							}
							if ( elm.dataset.columns ) {
								columns = parseInt(elm.dataset.columns);
							}
							const submenuMacy = new Macy({
								container: elm,
								columns: columns
							});
							setTimeout(()=>{
								submenuMacy.reInit();
							}, 100);
						})
					}
				</script>
			{%- endif -%}

		</nav>

	</div>

</div>