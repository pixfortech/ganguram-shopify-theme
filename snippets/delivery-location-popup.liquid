{%- comment -%}
  Ganguram delivery location popup — markup only (Phase 2.1d; redesigned 2.8B).
  Behaviour: assets/ganguram-delivery-popup.js + assets/ganguram-saved-locations.js
             (both use window.GanguramZone).
  Styles:    assets/ganguram-delivery-popup.css.

  Rendered ONCE (in layout/theme.liquid, after the resolver). Hidden by default;
  opens on first visit / when a blocked Add-to-Cart or Buy Now is clicked, or from
  the header "Delivering to…" trigger. Pincode entry/selection display only — no
  cart/checkout/availability/Google logic. Sections, top → bottom:
    header (title + close) · helper · current location · pincode entry ·
    recent locations · saved addresses (logged-in) · examples.
{%- endcomment -%}
<div class="ganguram-delivery-popup" id="ganguram-delivery-popup" data-gdp-root hidden>
  <div class="ganguram-delivery-popup__overlay" data-gdp-overlay tabindex="-1"></div>
  <div class="ganguram-delivery-popup__dialog" role="dialog" aria-modal="true" aria-labelledby="gdp-title" aria-describedby="gdp-help">

    <div class="ganguram-delivery-popup__header">
      <h2 class="ganguram-delivery-popup__title" id="gdp-title" data-gdp-title>Choose delivery location</h2>
      <button type="button" class="ganguram-delivery-popup__close" data-gdp-close aria-label="Close" hidden>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <p class="ganguram-delivery-popup__help" id="gdp-help" data-gdp-message>We use your pincode only to show what’s available in your area.</p>

    {%- comment -%} Current location — shown only when a pincode is selected (JS toggles [data-gdp-current]). {%- endcomment -%}
    <div class="ganguram-delivery-popup__current" data-gdp-current hidden>
      <div class="ganguram-delivery-popup__current-top">
        <span class="ganguram-delivery-popup__current-label">Delivering to</span>
        <button type="button" class="ganguram-delivery-popup__clear" data-gdp-clear>Clear</button>
      </div>
      <span class="ganguram-delivery-popup__current-value" data-gdp-current-value></span>
    </div>

    {%- comment -%} Pincode entry. {%- endcomment -%}
    <div class="ganguram-delivery-popup__field">
      <label class="ganguram-delivery-popup__label" for="gdp-input">Enter pincode</label>
      <div class="ganguram-delivery-popup__row">
        <input
          type="text"
          id="gdp-input"
          class="ganguram-delivery-popup__input"
          data-gdp-input
          inputmode="numeric"
          pattern="[0-9]*"
          maxlength="6"
          autocomplete="postal-code"
          placeholder="6-digit pincode"
          aria-label="Delivery pincode"
        >
        <button type="button" class="ganguram-delivery-popup__apply" data-gdp-apply>Apply</button>
      </div>
      <p class="ganguram-delivery-popup__status" data-gdp-status role="status" aria-live="polite"></p>
    </div>

    {%- comment -%}
      Saved delivery locations (Phase 2.8A). Selection only — every choice goes through
      GanguramZone.setSelectedPincode (assets/ganguram-saved-locations.js). Saved
      addresses render only for a logged-in customer; guests see recent locations from
      localStorage. No Google Maps, no checkout autofill, no full-address storage for guests.
    {%- endcomment -%}
    <div class="ganguram-delivery-popup__section" data-gdp-recent-section hidden>
      <p class="ganguram-delivery-popup__section-title">Recent</p>
      <ul class="ganguram-delivery-popup__chips" data-gdp-recent></ul>
    </div>

    {%- if customer -%}
      <div class="ganguram-delivery-popup__section" data-gdp-saved-section>
        <p class="ganguram-delivery-popup__section-title">Saved addresses</p>
        {%- if customer.addresses.size > 0 -%}
          <ul class="ganguram-delivery-popup__addr-list">
            {%- for address in customer.addresses limit: 6 -%}
              {%- assign gdp_zip = address.zip | remove: ' ' -%}
              {%- if gdp_zip != blank -%}
                <li>
                  <button
                    type="button"
                    class="ganguram-delivery-popup__addr"
                    data-gdp-saved-item
                    data-gdp-zip="{{ gdp_zip | escape }}"
                  >
                    <span class="ganguram-delivery-popup__addr-name">
                      {{- address.first_name | escape }} {{ address.last_name | escape -}}
                      {%- if address == customer.default_address %} <span class="ganguram-delivery-popup__addr-tag">Default</span>{% endif -%}
                    </span>
                    <span class="ganguram-delivery-popup__addr-place">
                      {%- if address.city != blank %}{{ address.city | escape }}{% endif -%}
                      {%- if address.province != blank %}, {{ address.province | escape }}{% endif -%}
                      {%- if address.city != blank or address.province != blank %} · {% endif %}{{ gdp_zip | escape -}}
                    </span>
                    {%- if address.address1 != blank -%}
                      <span class="ganguram-delivery-popup__addr-full">
                        {{- address.address1 | escape -}}
                        {%- if address.address2 != blank %}, {{ address.address2 | escape }}{% endif -%}
                      </span>
                    {%- endif -%}
                  </button>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- else -%}
          <p class="ganguram-delivery-popup__empty">No saved addresses yet. Add one in your account to reuse it here.</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <p class="ganguram-delivery-popup__examples">Kolkata <span>700008</span> · PAN India <span>110001</span></p>
  </div>
</div>
