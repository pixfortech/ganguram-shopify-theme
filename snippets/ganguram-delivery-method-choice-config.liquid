{%- comment -%}
  Ganguram — Persist cart delivery choice for checkout (Phase 2.12H).

  Publishes window.GanguramDeliveryMethodChoiceConfig and loads the module that mirrors
  the customer's chosen delivery method (derived from the EXISTING cart date-picker
  Standard / 4 Hours toggle + the selected zone) into two cart attributes a Delivery
  Customization (a Shipzy rule, or a Shopify Delivery Customization Function) can match on
  to HIDE non-selected methods at checkout:

    ganguram_preferred_delivery_method = STD | 4HR | PAN_INDIA
    ganguram_preferred_delivery_label  = Standard Delivery | 4 hours delivery | PAN India Shipping

  ESTIMATE / handoff only. It does NOT change ShipZip rate amounts, the 4HR/STD service
  codes, the distance slabs, product eligibility, the pincode resolver, MOV, the
  unavailable-items modal, the Custom Box Builder, or any date-picker attribute NAMES
  (the date keys below are READ from the date-picker config, never renamed). Merge-only
  cart writes; fail-open. See docs/cart-delivery-method-checkout-sync.md for the Shipzy
  rule / Delivery Customization Function setup.
{%- endcomment -%}
<script>
  window.GanguramDeliveryMethodChoiceConfig = {
    // HOTFIX (2.12K): DISABLED by default to fully isolate the checkout address/pincode prefill.
    // While false the module is INERT — no cart writes, no DOM, no listeners — so it cannot
    // affect the pincode/address auto-fetch, the delivery popup, or the prefill. The read-only
    // diagnostics (GanguramDeliveryMethodChoice.debugState / inspectCartAttributes) still work.
    // Re-enable (set to true) ONLY after the prefill is confirmed working; then the method/date
    // -> checkout-hiding handoff resumes. The calendar date picker is a SEPARATE module and stays on.
    enabled: false,
    updateUrl: {{ routes.cart_url | append: '/update.js' | json }},
    cartUrl: {{ routes.cart_url | append: '.js' | json }},
    debounceMs: 400,
    keys: {
      method: {{ 'ganguram_preferred_delivery_method' | json }},
      label: {{ 'ganguram_preferred_delivery_label' | json }},
      // Readable order attribute (shown in Shopify order "Additional details"). Single owner —
      // the date picker reads this to restore its toggle but no longer writes it.
      orderMethod: {{ 'Delivery Method' | json }}
    },
    // Readable labels saved alongside the code — set these to your EXACT ShipZip rate
    // names so a Shipzy rule / the Delivery Customization Function can match on them.
    labels: {
      STD: {{ 'Standard Delivery' | json }},
      '4HR': {{ '4 hours delivery' | json }},
      PAN_INDIA: {{ 'PAN India Shipping' | json }}
    }
  };
</script>
{{ 'ganguram-delivery-method-choice.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ganguram-delivery-method-choice.js' | asset_url }}" defer></script>
