{%- comment -%}
  Ganguram — Cart eligibility config (Phase 2.7A).

  Passes the localized Ajax cart update URL + the all-products URL to the cart
  eligibility module, then loads it. Display + Ajax cart-line removal only; reuses
  the shared zone eligibility rule (window.GanguramZoneRules). No checkout / MOV /
  date-slot / shipping-rate / payment / ShipZip / SBZ / zipLogic logic.
{%- endcomment -%}
<script>
  window.GanguramCartConfig = {
    updateUrl: {{ routes.cart_url | append: '/update.js' | json }},
    addUrl: {{ routes.cart_url | append: '/add.js' | json }},
    cartUrl: {{ routes.cart_url | append: '.js' | json }},
    allProductsUrl: {{ routes.all_products_collection_url | default: '/collections/all' | json }},
    undoEnabled: {% if settings.ganguram_cart_undo_enabled == false %}false{% else %}true{% endif %},
    undoSeconds: {{ settings.ganguram_cart_undo_seconds | default: 10 | json }},
    undoMessage: {{ settings.ganguram_cart_undo_message | default: 'Items removed. Undo available for {seconds} seconds.' | json }}
  };
</script>
{{ 'ganguram-cart-eligibility.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ganguram-cart-eligibility.js' | asset_url }}" defer></script>
