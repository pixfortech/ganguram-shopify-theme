{%- comment -%}
  Ganguram — Empty collection warning config (Phase 2.7C).

  Publishes window.GanguramEmptyCollectionConfig from theme settings
  (Theme settings → "Ganguram — Empty collection redirect"), then loads the scoped
  module. Display only: it shows a warning + countdown and redirects to the
  homepage when a collection has zero products visible for the selected pincode.
  It reuses the product-zone filter output + GanguramZone; no checkout / shipping /
  MOV / ShipZip / SBZ / zipLogic logic, no pincode lists.
{%- endcomment -%}
{%- capture gdp_fallback_redirect_text -%}Redirecting to homepage in {seconds} seconds.{%- endcapture -%}
{%- assign gdp_redirect_text = settings.ganguram_ecr_redirect_text | default: gdp_fallback_redirect_text -%}
<script>
  window.GanguramEmptyCollectionConfig = {
    enabled: {% if settings.ganguram_ecr_enabled %}true{% else %}false{% endif %},
    seconds: {{ settings.ganguram_ecr_seconds | default: 6 | json }},
    title: {{ settings.ganguram_ecr_title | default: 'No products available for this pincode' | json }},
    body: {{ settings.ganguram_ecr_body | default: 'No products in this collection are available for the selected pincode.' | json }},
    body4hr: {{ settings.ganguram_ecr_body_4hr | default: '4 Hours Delivery is available only in selected Kolkata areas. Please change your pincode or continue with normal delivery.' | json }},
    zeroCountText: {{ settings.ganguram_ecr_zero_count | default: '0 products available for this pincode' | json }},
    redirectText: {{ gdp_redirect_text | json }},
    target: {{ settings.ganguram_ecr_target | default: '/' | json }}
  };
</script>
{{ 'ganguram-empty-collection-warning.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ganguram-empty-collection-warning.js' | asset_url }}" defer></script>
